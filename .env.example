# Copy this file to `.env` (untracked — see .gitignore) and fill in real values.
# Loaded automatically by query/run.py and evals/run.py via python-dotenv; a real
# environment variable always overrides whatever's in this file.

# Groq (Llama 3.1 8B) — retrieval's QueryRouter, for query classification/routing.
# Get a key at https://console.groq.com. Without it, query.run / evals.run fall back
# to an offline router (query embedding + your --tickers/--sectors profile, no intent
# inference) — pass --offline-router to force that path even when a key is set.
GROQ_API_KEY=

# Gemini Flash — generation's Synthesizer, for the final cited answer.
# Get a key at https://aistudio.google.com/apikey. Also requires: pip install google-genai
# Without both the key and the package, query.run / evals.run stop after retrieval.
GEMINI_API_KEY=

# Speeds up local MiniLM loads (retrieval/query embedding) once the model is cached at
# ~/.cache/huggingface/hub — skips the Hub connectivity check on every process start.
# Leave commented until after the first run has downloaded the model.
# HF_HUB_OFFLINE=1

# SEC EDGAR — required User-Agent for shared/tickers.py's daily ticker-list refresh
# (shared/refresh_tickers_cli.py, run via cron/Task Scheduler). SEC silently rejects
# requests with no identifying email. Not read on any request path.
SEC_USER_AGENT_EMAIL=
